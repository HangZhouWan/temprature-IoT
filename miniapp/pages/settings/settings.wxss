.container { padding: 24rpx; }

.section { background: #1e293b; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; color: #94a3b8; margin-bottom: 24rpx; display: block; }

.form-row { display: flex; gap: 24rpx; }
.form-item { flex: 1; }
.form-label { font-size: 24rpx; color: #64748b; margin-bottom: 10rpx; display: block; }
.form-input { background: #0f172a; border-radius: 12rpx; padding: 18rpx 24rpx; font-size: 30rpx; color: #e2e8f0; }

.tip { background: #1e293b; border-left: 4rpx solid #60a5fa; border-radius: 8rpx; padding: 20rpx 24rpx; margin-bottom: 32rpx; font-size: 24rpx; color: #94a3b8; line-height: 1.6; }

.save-btn { background: #3b82f6; color: #fff; font-size: 30rpx; border-radius: 16rpx; padding: 24rpx 0; border: none; width: 100%; }

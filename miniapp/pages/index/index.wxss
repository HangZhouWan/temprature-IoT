.container { padding: 24rpx; padding-bottom: 48rpx; }

/* 标题 */
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 40rpx; font-weight: 700; }
.settings-btn { background: #3b82f6; color: #fff; padding: 10rpx 24rpx; border-radius: 10rpx; font-size: 24rpx; }

/* 统计卡片 */
.counts { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.count-item { flex: 1; background: #1e293b; border-radius: 16rpx; padding: 18rpx 12rpx; text-align: center; }
.count-item.high { border-top: 4rpx solid #ef4444; }
.count-item.low { border-top: 4rpx solid #3b82f6; }
.count-item.warning { border-top: 4rpx solid #f59e0b; }
.count-item.offline { border-top: 4rpx solid #94a3b8; }
.count-num { font-size: 40rpx; font-weight: 700; display: block; }
.count-item.high .count-num { color: #ef4444; }
.count-item.low .count-num { color: #3b82f6; }
.count-item.warning .count-num { color: #f59e0b; }
.count-item.offline .count-num { color: #94a3b8; }
.count-label { font-size: 22rpx; color: #94a3b8; margin-top: 2rpx; display: block; }

/* 阈值 */
.threshold-bar { background: #1e293b; border-radius: 10rpx; padding: 14rpx 20rpx; margin-bottom: 20rpx; font-size: 22rpx; color: #94a3b8; }

/* 模式切换 */
.mode-toggle { display: flex; background: #1e293b; border-radius: 14rpx; padding: 6rpx; margin-bottom: 20rpx; }
.toggle-item { flex: 1; text-align: center; padding: 12rpx 0; border-radius: 10rpx; font-size: 26rpx; color: #94a3b8; }
.toggle-item.active { background: #3b82f6; color: #fff; }

/* 地图 */
.map-wrap { position: relative; border-radius: 16rpx; overflow: hidden; border: 2rpx solid #334155; }
.locate-btn {
  position: absolute; bottom: 20rpx; right: 20rpx;
  width: 72rpx; height: 72rpx; background: #1e293b;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
}
.locate-btn:active { background: #334155; }
.locate-icon { font-size: 36rpx; color: #e2e8f0; }
.map-hint { text-align: center; padding: 14rpx 0; font-size: 22rpx; color: #64748b; }

/* 设备列表 */
.device-list { display: flex; flex-direction: column; gap: 12rpx; }
.device-card {
  display: flex; align-items: center; background: #1e293b;
  border-radius: 16rpx; padding: 22rpx 24rpx; gap: 18rpx;
}
.device-card.warning { border-left: 5rpx solid #f59e0b; }

.dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.dot.online { background: #22c55e; }
.dot.offline { background: #94a3b8; }
.dot.warning { background: #f59e0b; animation: blink 1s infinite; }
@keyframes blink { 50% { opacity: 0.3; } }

.card-info { flex: 1; }
.name-row { display: flex; align-items: center; gap: 10rpx; }
.card-id { font-size: 28rpx; font-weight: 600; }
.new-badge {
  font-size: 18rpx;
  color: #ffffff;
  background: #ef4444;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.card-time { font-size: 22rpx; color: #64748b; margin-top: 2rpx; display: block; }

.card-values { display: flex; gap: 20rpx; align-items: center; }
.val { font-size: 28rpx; font-weight: 600; }
.val.temp { color: #f87171; }
.val.hum { color: #60a5fa; }
.val.offline { color: #94a3b8; font-size: 24rpx; }

.empty { text-align: center; padding: 80rpx 0; color: #64748b; font-size: 28rpx; }

.container { padding: 24rpx; padding-bottom: 48rpx; }

.header { margin-bottom: 24rpx; }

.name-display { padding: 8rpx 0; }
.name-display:active { opacity: 0.6; }
.device-id { font-size: 36rpx; font-weight: 700; display: block; }
.edit-hint { font-size: 22rpx; color: #64748b; margin-top: 4rpx; display: block; }
.device-id-raw { font-size: 22rpx; color: #64748b; margin-top: 4rpx; display: block; }

.name-edit { margin-bottom: 12rpx; }
.name-input { background: #0f172a; border: 2rpx solid #3b82f6; border-radius: 10rpx; padding: 14rpx 20rpx; font-size: 30rpx; color: #e2e8f0; margin-bottom: 12rpx; }
.name-actions { display: flex; gap: 16rpx; }
.name-btn { font-size: 26rpx; padding: 10rpx 28rpx; border-radius: 10rpx; }
.name-btn.cancel { background: #334155; color: #94a3b8; }
.name-btn.save { background: #3b82f6; color: #fff; }

.update-time { font-size: 24rpx; color: #94a3b8; margin-top: 6rpx; display: block; }

/* 数据卡片 */
.cards { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.card { flex: 1; background: #1e293b; border-radius: 24rpx; padding: 28rpx; }
.temp-card { border-left: 6rpx solid #f87171; }
.hum-card { border-left: 6rpx solid #60a5fa; }
.card-label { font-size: 26rpx; color: #94a3b8; }
.card-value { font-size: 60rpx; font-weight: 700; margin: 8rpx 0; }
.card-unit { font-size: 28rpx; font-weight: 400; color: #94a3b8; }

/* 图表 */
.chart-box { background: #1e293b; border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx; }
.chart-title { font-size: 28rpx; color: #94a3b8; margin-bottom: 16rpx; display: block; }
.chart { width: 100%; height: 420rpx; }
.legend { display: flex; gap: 32rpx; margin-top: 16rpx; }
.legend-item { font-size: 24rpx; color: #94a3b8; display: flex; align-items: center; gap: 8rpx; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.temp-dot { background: #f87171; }
.hum-dot { background: #60a5fa; }

/* 表格 */
.table-box { background: #1e293b; border-radius: 24rpx; padding: 24rpx; }
.table-header { display: flex; font-size: 24rpx; color: #94a3b8; padding-bottom: 12rpx; border-bottom: 2rpx solid #334155; margin-bottom: 8rpx; }
.table-body { max-height: 500rpx; }
.table-row { display: flex; padding: 12rpx 0; border-bottom: 2rpx solid #1e293b; font-size: 24rpx; }
.table-row:nth-child(odd) { background: #1a2332; }
.col { flex: 1; text-align: center; }
.col-wide { flex: 2; text-align: left; }

.empty { text-align: center; padding: 48rpx 0; color: #64748b; font-size: 26rpx; }

.delete-section { margin-top: 32rpx; display: flex; justify-content: center; }
.delete-btn {
  background: transparent;
  border: 2rpx solid #ef4444;
  border-radius: 14rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: #ef4444;
}
.delete-btn:active { background: rgba(239, 68, 68, 0.1); }

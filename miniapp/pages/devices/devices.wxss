.container { padding: 24rpx; }

.header { margin-bottom: 28rpx; }
.title { font-size: 40rpx; font-weight: 700; display: block; }
.subtitle { font-size: 24rpx; color: #94a3b8; margin-top: 6rpx; display: block; }

.device-list { display: flex; flex-direction: column; gap: 16rpx; }

.device-card {
  display: flex;
  align-items: center;
  background: #1e293b;
  border-radius: 20rpx;
  padding: 28rpx;
  gap: 20rpx;
}

.dot { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.dot.online { background: #22c55e; }
.dot.offline { background: #94a3b8; }
.dot.warning { background: #f59e0b; animation: blink 1s infinite; }
@keyframes blink { 50% { opacity: 0.3; } }

.card-center { flex: 1; }
.name-row { display: flex; align-items: center; gap: 12rpx; }
.device-id { font-size: 30rpx; font-weight: 600; }
.new-badge {
  font-size: 18rpx;
  color: #ffffff;
  background: #ef4444;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.device-id-raw { font-size: 20rpx; color: #64748b; display: block; }
.device-time { font-size: 22rpx; color: #64748b; margin-top: 4rpx; display: block; }

.card-right { display: flex; align-items: center; gap: 16rpx; }
.val { font-size: 28rpx; font-weight: 600; }
.val.temp { color: #f87171; }
.val.hum { color: #60a5fa; }
.val.offline { color: #94a3b8; font-size: 24rpx; }
.arrow { font-size: 32rpx; color: #64748b; }

.empty { text-align: center; padding: 100rpx 0; color: #64748b; font-size: 28rpx; }

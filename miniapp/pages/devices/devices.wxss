.container { padding: 24rpx; }

/* 概览 */
.summary { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.sum-item { flex: 1; background: #1e293b; border-radius: 20rpx; padding: 24rpx; text-align: center; }
.sum-item.online { border-top: 4rpx solid #22c55e; }
.sum-item.offline { border-top: 4rpx solid #94a3b8; }
.sum-item.warning { border-top: 4rpx solid #f59e0b; }
.sum-num { font-size: 52rpx; font-weight: 700; display: block; }
.sum-label { font-size: 24rpx; color: #94a3b8; display: block; margin-top: 4rpx; }

/* 筛选 */
.filter-bar { display: flex; gap: 16rpx; align-items: center; margin-bottom: 24rpx; }
.filter-btn { padding: 10rpx 28rpx; border-radius: 16rpx; font-size: 26rpx; background: #1e293b; color: #94a3b8; }
.filter-btn.active { background: #3b82f6; color: #fff; }
.online-btn.active { background: #22c55e; }
.offline-btn.active { background: #64748b; }
.warning-btn.active { background: #f59e0b; color: #0f172a; }
.refresh-link { font-size: 26rpx; color: #60a5fa; margin-left: auto; }

/* 设备卡片 */
.device-list { display: flex; flex-direction: column; gap: 20rpx; }
.device-card { background: #1e293b; border-radius: 20rpx; padding: 28rpx; }
.device-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.device-id { font-size: 30rpx; font-weight: 600; display: flex; align-items: center; gap: 10rpx; }
.device-meta { font-size: 22rpx; color: #64748b; margin-top: 6rpx; display: block; }
.status-dot { width: 14rpx; height: 14rpx; border-radius: 50%; flex-shrink: 0; }
.status-dot.online { background: #22c55e; }
.status-dot.offline { background: #94a3b8; }
.status-dot.warning { background: #f59e0b; animation: blink 1s infinite; }
@keyframes blink { 50% { opacity: 0.3; } }

.status-badge { font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 20rpx; font-weight: 500; }
.status-badge.online { background: #22c55e33; color: #22c55e; }
.status-badge.offline { background: #64748b33; color: #94a3b8; }
.status-badge.warning { background: #f59e0b33; color: #f59e0b; }

/* 数据行 */
.device-data { display: flex; gap: 32rpx; padding: 20rpx; background: #0f172a; border-radius: 12rpx; }
.data-item { display: flex; flex-direction: column; gap: 6rpx; }
.data-label { font-size: 22rpx; color: #64748b; }
.data-value { font-size: 30rpx; font-weight: 600; }
.data-value.temp { color: #f87171; }
.data-value.hum { color: #60a5fa; }

/* 告警 */
.device-alert { margin-top: 16rpx; padding: 16rpx 20rpx; background: #f59e0b18; border-left: 4rpx solid #f59e0b; border-radius: 8rpx; font-size: 24rpx; color: #f59e0b; }
.offline-alert { background: #64748b18; border-left-color: #64748b; color: #94a3b8; }

/* 空 */
.empty { text-align: center; padding: 80rpx 0; color: #64748b; font-size: 28rpx; }

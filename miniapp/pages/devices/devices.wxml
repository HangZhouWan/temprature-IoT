<view class="container">
  <view class="header">
    <text class="title">传感器列表</text>
    <text class="subtitle">{{devices.length}} 台设备</text>
  </view>

  <view class="device-list">
    <view class="device-card" wx:for="{{devices}}" wx:key="device_id"
          bindtap="goDetail" data-id="{{item.device_id}}">
      <view class="card-left">
        <view class="dot {{item.status}}"></view>
      </view>
      <view class="card-center">
        <view class="name-row">
          <text class="device-id">{{item.displayName}}</text>
          <text class="new-badge" wx:if="{{item.is_new}}">NEW</text>
        </view>
        <text class="device-id-raw" wx:if="{{item.displayName !== item.device_id}}">{{item.device_id}}</text>
        <text class="device-time">{{item.last_seen}}</text>
      </view>
      <view class="card-right">
        <view class="val temp" wx:if="{{item.status !== 'offline'}}">{{item.tempStr}}</view>
        <view class="val hum" wx:if="{{item.status !== 'offline'}}">{{item.humStr}}</view>
        <view class="val offline" wx:else>离线</view>
        <text class="arrow">></text>
      </view>
    </view>

    <view class="empty" wx:if="{{devices.length === 0}}">
      <text>暂无设备数据</text>
    </view>
  </view>
</view>
